{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "netlify/functions/info.js",
      "use": "@vercel/node"
    },
    {
      "src": "netlify/functions/download.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/.netlify/functions/info",
      "dest": "netlify/functions/info.js"
    },
    {
      "src": "/.netlify/functions/download",
      "dest": "netlify/functions/download.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}
